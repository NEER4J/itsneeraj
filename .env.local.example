# Required for the chat panel. Without it the chat shows a polite "offline" message.
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional. Defaults to "anthropic/claude-haiku-4.5".
# Other good options on OpenRouter:
#   google/gemini-2.5-flash       (very cheap, fast)
#   openai/gpt-4o-mini            (cheap, decent)
#   anthropic/claude-sonnet-4.5   (smarter, costs more)
OPENROUTER_MODEL=

# Optional. OpenRouter uses this for analytics/attribution.
OPENROUTER_REFERER=https://itsneeraj.com
